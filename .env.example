# Convex deployment URL - get from Convex dashboard
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex HTTP site URL for auth routes (e.g., https://your-deployment.convex.site)
PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Site URL for auth callbacks (e.g., http://localhost:5173 in dev)
SITE_URL=http://localhost:5173

# Dev tunnel URL for external tools (Firecrawl, etc.) that can't reach localhost
# Cloudflare Tunnel: cloudflared tunnel run babylon-dev
# DEV_TUNNEL_URL=https://dev.schulie.com
# Verifier app URL for cross-origin Better Auth requests (set in all environments that use verifier)
VERIFIER_SITE_URL=http://localhost:5178

# Extra trusted origins for auth (comma-separated, e.g. Cloudflare Tunnel subdomains)
# AUTH_EXTRA_TRUSTED_ORIGINS=https://dev.schulie.com,https://verifier.schulie.com

# Auth hardening defaults:
# - Production requires verified emails by default.
# - Localhost trusted origins are disabled in production by default.
# Uncomment only if you explicitly need to override during rollout.
# AUTH_REQUIRE_EMAIL_VERIFICATION=true
# AUTH_ALLOW_LOCALHOST_ORIGINS=false
# AUTH_ALLOW_UNVERIFIED_EMAILS_PROD=false

# VAPID keys for web push notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Google Cloud Translation API key (for translation verification)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# PayFast billing (sandbox example)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# Leave blank only if PayFast account passphrase is also blank.
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=http://localhost:5173/billing/return
PAYFAST_CANCEL_URL=http://localhost:5173/billing/cancel
# Must point to your Convex HTTP deployment endpoint.
PAYFAST_NOTIFY_URL=https://your-deployment.convex.site/webhooks/payfast

PAYFAST_ENABLE_RECURRING=true

# Dev-only billing tier switch in Settings (free/ai/pro without checkout).
# Enabled automatically on localhost; use this flag to force-enable in other dev environments.
BILLING_DEV_TOGGLE=true

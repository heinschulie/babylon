{
	"name": "babylon-monorepo",
	"private": true,
	"version": "0.0.1",
	"packageManager": "bun@1.2.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --filter=@babylon/web",
		"dev:verifier": "turbo run dev --filter=@babylon/verifier",
		"build": "turbo run build",
		"build:web": "turbo run build --filter=@babylon/web",
		"build:verifier": "turbo run build --filter=@babylon/verifier",
		"preview": "turbo run preview --filter=@babylon/web",
		"preview:verifier": "turbo run preview --filter=@babylon/verifier",
		"convex:dev": "bunx convex dev",
		"convex:codegen": "bunx convex codegen",
		"convex:check-generated": "sh ./scripts/check-convex-generated.sh",
		"lockfile:check": "sh ./scripts/check-lockfile-sync.sh",
		"hooks:install": "sh ./scripts/setup-git-hooks.sh",
		"convex:deploy": "bunx convex deploy",
		"convex:logs": "bunx convex logs",
		"check": "turbo run check",
		"check:watch": "turbo run check:watch --filter=@babylon/web",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"test:run": "turbo run test:run",
		"adw:webhook": "bun run adws/triggers/webhook.ts",
		"adw:cron": "bun run adws/triggers/cron.ts",
		"adw:plan-build": "bun run adws/workflows/classic/adw_plan_build.ts",
		"adw:test": "vitest run adws/tests/"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"bun": "^1.3.9",
		"convex": "^1.31.6",
		"turbo": "^2.5.8",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.79",
		"@aws-sdk/client-s3": "^3.1014.0",
		"@testing-library/svelte": "^5.2.4",
		"playwright": "^1.58.2"
	}
}
